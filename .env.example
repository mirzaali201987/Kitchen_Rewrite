# Copy this file to .env.local and fill in both values.
# Never commit .env.local to git.

# Groq API key — the LLM that rewrites recipes.
# Get a free key at https://console.groq.com/keys
# Keys start with "gsk_".
GROQ_API_KEY=

# Unsplash API key — for fetching food photos.
# Get a free Access Key at https://unsplash.com/developers
# 1. Sign up / log in
# 2. Click "New Application", accept both checkboxes, fill in app name + description
# 3. Copy the "Access Key" (NOT the Secret Key)
# Keys are ~43 characters. Free demo tier: 50 requests per hour.
UNSPLASH_ACCESS_KEY=
